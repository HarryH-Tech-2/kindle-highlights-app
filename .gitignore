# Firebase
# google-services.json / GoogleService-Info.plist contain public app identifiers
# (API key is restricted by package name + SHA-1, not a secret). Firebase's own
# docs recommend committing these for native apps so EAS / CI builds can find
# them. Keep the iOS plist gitignored until we add iOS support.
GoogleService-Info.plist

# typescript
*.tsbuildinfo

